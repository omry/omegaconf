name: Update Backlog
run-name: "backlog: ${{ github.event_name }}.${{ github.event.action }} #${{ github.event.issue.number || github.event.pull_request.number || 'n/a' }} ${{ github.event.issue.title || github.event.pull_request.title }}"

on:
  issues:
    types: [opened, closed, labeled, unlabeled, reopened]
  pull_request:
    types: [opened, closed, labeled, unlabeled, reopened]
  schedule:
    - cron: '0 7 * * *'  # daily fallback
  workflow_dispatch:

permissions:
  contents: write
  issues: read
  pull-requests: read

env:
  BACKLOG_TOOL_PIP: __BACKLOG_TOOL_PIP__

jobs:
  log-event:
    if: github.event_name == 'issues' || github.event_name == 'pull_request'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          ref: backlog
          path: backlog-branch
      - name: Append event to log
        env:
          EVENT_NAME: ${{ github.event_name }}
          EVENT_ACTION: ${{ github.event.action }}
          ISSUE_NUMBER: ${{ github.event.issue.number || github.event.pull_request.number }}
        run: |
          jq -n \
            --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            --arg event "$EVENT_NAME" \
            --arg action "$EVENT_ACTION" \
            --arg number "$ISSUE_NUMBER" \
            '{ts: $ts, event: $event, action: $action, number: $number}' \
            >> backlog-branch/events.jsonl
      - name: Push event log
        run: |
          cd backlog-branch
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add events.jsonl
          git diff --cached --quiet && exit 0
          git commit -m "event: ${{ github.event_name }}.${{ github.event.action }} #${{ github.event.issue.number || github.event.pull_request.number }} [skip ci]"
          for i in 1 2 3; do
            if git pull --rebase origin backlog && git push; then
              exit 0
            fi
            sleep $((i * 3))
          done
          exit 1

  process:
    concurrency:
      group: update-backlog
      cancel-in-progress: true
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          ref: main
      - uses: actions/checkout@v4
        with:
          ref: backlog
          path: backlog-branch
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - name: Install backlog-tool
        run: pip install "$BACKLOG_TOOL_PIP"
      - name: Debounce (event-triggered runs only)
        if: github.event_name != 'schedule' && github.event_name != 'workflow_dispatch'
        run: sleep 60
      - name: Refresh backlog branch after debounce
        run: |
          cd backlog-branch
          git pull --rebase origin backlog
      - name: Seed backlog files for tool
        run: |
          cp backlog-branch/BACKLOG.md BACKLOG.md 2>/dev/null || true
          cp backlog-branch/BACKLOG-UPDATES.md BACKLOG-UPDATES.md 2>/dev/null || true
      - name: Update backlog
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          backlog-tool update \
            --snapshot-path backlog-branch/last_snapshot.json \
            --event-log-path backlog-branch/events.jsonl \
            --data-json-path backlog-branch/backlog.json \
            --updates-jsonl-path backlog-branch/updates.jsonl \
            --commit-msg-path /tmp/backlog_commit_msg.txt
      - name: Stage web assets on backlog branch
        run: |
          backlog-tool dump-web --output backlog-branch/index.html
      - name: Commit to backlog branch
        run: |
          cp BACKLOG.md backlog-branch/BACKLOG.md
          [ -f BACKLOG-UPDATES.md ] && cp BACKLOG-UPDATES.md backlog-branch/BACKLOG-UPDATES.md || true
          cd backlog-branch
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add BACKLOG.md BACKLOG-UPDATES.md last_snapshot.json events.jsonl \
                  backlog.json updates.jsonl index.html
          git diff --cached --quiet && exit 0
          COMMIT_MSG=$(cat /tmp/backlog_commit_msg.txt 2>/dev/null || echo "backlog: sync [skip ci]")
          git commit -m "$COMMIT_MSG"
          for i in 1 2 3; do
            if git pull --rebase origin backlog && git push; then
              exit 0
            fi
            sleep $((i * 3))
          done
          exit 1
